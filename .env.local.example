# 이 파일은 예시 파일입니다. 실제 값은 .env.local에 저장하세요.
# .env.local은 .gitignore에 포함되어 있어 GitHub에 올라가지 않습니다.

# Notion API (나중에 콘텐츠 CMS로 연결할 때 사용)
NOTION_API_KEY=your_notion_integration_secret_here
NOTION_DATABASE_ID=your_database_id_here

# 뉴스레터 구독 (Mailchimp 또는 다른 서비스 연결 시)
# MAILCHIMP_API_KEY=
# MAILCHIMP_LIST_ID=
